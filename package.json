{
  "name": "ef-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo EF — React Native (Ignite + Tamagui) + NestJS Microservicios",
  "workspaces": [
    "apps/mobile",
    "apps/backend"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "mobile:android": "npm run android --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "backend:build": "npm run build --workspace=apps/backend",
    "backend:gateway": "npm run start:gateway --workspace=apps/backend",
    "backend:auth": "npm run start:auth --workspace=apps/backend",
    "backend:users": "npm run start:users --workspace=apps/backend",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "docker:build": "docker compose -f infrastructure/docker/docker-compose.yml build"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
