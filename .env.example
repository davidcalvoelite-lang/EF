# ===========================================
# EF Platform — Variables de Entorno
# ===========================================
# Copia este archivo a .env y ajusta los valores

# --- General ---
NODE_ENV=development

# --- API Gateway ---
API_GATEWAY_PORT=3000

# --- Microservicios (TCP) ---
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3001
USERS_SERVICE_HOST=localhost
USERS_SERVICE_PORT=3002

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ef_user
POSTGRES_PASSWORD=ef_password
POSTGRES_DB=ef_db

# --- MongoDB ---
MONGO_USER=ef_user
MONGO_PASSWORD=ef_password
MONGO_DB=ef_mongo
MONGODB_URI=mongodb://ef_user:ef_password@localhost:27017/ef_mongo?authSource=admin

# --- Auth ---
JWT_SECRET=ef-dev-secret-change-in-production

# --- AWS (despliegue) ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
